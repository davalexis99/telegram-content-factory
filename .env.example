# Telegram Content Factory — Environment Variables
# Copy to .env and fill in your keys

# Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenAI API key (for GPT-4.1 content generation)
OPENAI_API_KEY=

# Notion integration token + parent page ID
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Supabase (optional — for logging/analytics)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App settings
LOG_LEVEL=INFO
POLLING_INTERVAL=2
