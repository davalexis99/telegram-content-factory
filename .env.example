# Telegram Content Factory — Environment Variables
# Copy to .env and fill in your keys

# DeepSeek API (primary LLM — https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# OpenAI API key (fallback if DeepSeek is unset)
# OPENAI_API_KEY=

# Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Notion integration token + parent page ID
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Supabase (optional — for logging/analytics)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App settings
LOG_LEVEL=INFO
POLLING_INTERVAL=2
